      { id: 8, title: "CHARAN SHARAN KI VANDANA", src: "songs/08 CHARAN SHARAN KI VANDANA", artist: "Radhaswami", genre: "Bhajan", duration: 280 },
      { id: 9, title: "RADHA SWAMI NAAM SURIR", src: "songs/09-RADHA-SWAMI-NAAM-SURIR-MAN-MEIN.mp3", artist: "Radhaswami", genre: "Bhajan", duration: 355 },
      { id: 10, title: "AARTI AAGE RADHA SWAMI KI", src: "songs/10-AARTI-AAGE-RADHA-SWAMI-KI.mp3", artist: "Radhaswami", genre: "Aarti", duration: 390 },
      { id: 11, title: "NAMO NAMO SATGURU HAATH JODE", src: "songs/11-NAMO-NAMO-SATGURU-HAATH-JODE-KARU-VINNTI.mp3", artist: "Radhaswami", genre: "Bhajan", duration: 320 },
      { id: 12, title: "MANWA TU BANA MADARI", src: "songs/12-MANWA-TU-BANA-MADARI.mp3", artist: "Radhaswami", genre: "Bhajan", duration: 275 },
      { id: 13, title: "MAIN TO DHUDHAT DOLU", src: "songs/13-MAIN-TO-DHUDHAT-DOLU-HE-SATGURU.mp3", artist: "Radhaswami", genre: "Bhajan", duration: 345 },
      { id: 14, title: "TAN MAN DHAN KI BAAZI", src: "songs/15-TAN-MAN-DHAN-KI-BAAZI-LA-LE.mp3", artist: "Radhaswami", genre: "Bhajan", duration: 295 },
      { id: 15, title: "TANHE NAHI AAYA CHINA", src: "songs/16-TANHE-NAHI-AAYA-CHINA.mp3", artist: "Radhaswami", genre: "Bhajan", duration: 305 }
    ];

    // ==================== STATE MANAGEMENT ====================
    let state = {
      currentIndex: 0,
      currentTab: 'all',
      isPlaying: false,
      isShuffle: false,
      isRepeat: false,
      favorites: JSON.parse(localStorage.getItem('fav')) || [],
      plays: JSON.parse(localStorage.getItem('plays')) || 0,
      hours: JSON.parse(localStorage.getItem('hours')) || 0,
      searchTerm: ''
    };

    // Audio element
    const audio = new Audio();
    audio.volume = 0.7;
    audio.preload = 'metadata';

    // ==================== DOM ELEMENTS ====================
    const loadingScreen = document.getElementById('loadingScreen');
    const appContainer = document.getElementById('appContainer');
    const songList = document.getElementById('songList');
    const searchInput = document.getElementById('searchInput');
    const playPauseBtn = document.getElementById('playPauseBtn');
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    const shuffleBtn = document.getElementById('shuffleBtn');
    const repeatBtn = document.getElementById('repeatBtn');
    const favoriteBtn = document.getElementById('favoriteBtn');
    const shareBtn = document.getElementById('shareBtn');
    const infoBtn = document.getElementById('infoBtn');
    const topBtn = document.getElementById('topBtn');
    const progressBar = document.getElementById('progressBar');
    const progressContainer = document.getElementById('progressContainer');
    const currentTimeSpan = document.getElementById('currentTime');
    const totalTimeSpan = document.getElementById('totalTime');
    const currentTitle = document.getElementById('currentTitle');
    const currentArtist = document.getElementById('currentArtist');
    const toast = document.getElementById('toast');
    const infoModal = document.getElementById('infoModal');

    // ==================== INITIALIZE ====================
    function init() {
      // Hide loading after 1 second
      setTimeout(() => {
        loadingScreen.style.opacity = '0';
        setTimeout(() => {
          loadingScreen.style.display = 'none';
        }, 500);
      }, 1000);

      // Load first song
      if (songs.length > 0) {
        loadSong(0);
      }

      // Update stats
      updateStats();
      
      // Render songs
      renderSongs();

      // Add event listeners
      audio.addEventListener('timeupdate', updateProgress);
      audio.addEventListener('loadedmetadata', () => {
        totalTimeSpan.textContent = formatTime(audio.duration);
      });
      audio.addEventListener('ended', onSongEnd);

      // Tab listeners
      document.querySelectorAll('.tab').forEach(tab => {
        tab.addEventListener('click', () => switchTab(tab.dataset.tab));
      });

      // Search listener
      searchInput.addEventListener('input', () => {
        state.searchTerm = searchInput.value.toLowerCase();
        renderSongs();
      });

      // Control listeners
      playPauseBtn.addEventListener('click', togglePlayPause);
      prevBtn.addEventListener('click', playPrevious);
      nextBtn.addEventListener('click', playNext);
      shuffleBtn.addEventListener('click', toggleShuffle);
      repeatBtn.addEventListener('click', toggleRepeat);
      favoriteBtn.addEventListener('click', toggleFavorite);
      shareBtn.addEventListener('click', shareSong);
      infoBtn.addEventListener('click', showInfo);
      topBtn.addEventListener('click', scrollToTop);
      progressContainer.addEventListener('click', seek);
    }

    // ==================== SONG FUNCTIONS ====================
    function loadSong(index) {
      if (index < 0 || index >= songs.length) return;
      
      state.currentIndex = index;
      const song = songs[index];
      
      audio.src = song.src;
      currentTitle.textContent = song.title;
      currentArtist.textContent = `${song.artist} • ${song.genre}`;
      
      // Update favorite button
      updateFavoriteButton();
      
      // Render songs to show playing state
      renderSongs();
    }

    function playSong(index) {
      loadSong(index);
      audio.play().then(() => {
        state.isPlaying = true;
        updatePlayPauseIcon();
        
        // Update plays
        state.plays++;
        localStorage.setItem('plays', JSON.stringify(state.plays));
        document.getElementById('playsCount').textContent = state.plays;
        
        showToast(`🕉️ ${songs[index].title}`);
      }).catch(error => {
        console.error('Playback error:', error);
        showToast('Error playing song', 'error');
      });
    }

    function togglePlayPause() {
      if (audio.paused) {
        audio.play().then(() => {
          state.isPlaying = true;
          updatePlayPauseIcon();
        });
      } else {
        audio.pause();
        state.isPlaying = false;
        updatePlayPauseIcon();
      }
    }

    function updatePlayPauseIcon() {
      playPauseBtn.innerHTML = state.isPlaying ? 
        '<i class="fas fa-pause"></i>' : 
        '<i class="fas fa-play"></i>';
    }

    function playNext() {
      let nextIndex;
      if (state.isShuffle) {
        do {
          nextIndex = Math.floor(Math.random() * songs.length);
        } while (nextIndex === state.currentIndex && songs.length > 1);
      } else {
        nextIndex = (state.currentIndex + 1) % songs.length;
      }
      playSong(nextIndex);
    }

    function playPrevious() {
      const prevIndex = (state.currentIndex - 1 + songs.length) % songs.length;
      playSong(prevIndex);
    }

    function onSongEnd() {
      if (state.isRepeat) {
        audio.currentTime = 0;
        audio.play();
      } else {
        playNext();
      }
      
      // Update hours (roughly)
      state.hours += 0.0167; // ~1 minute
      localStorage.setItem('hours', JSON.stringify(Math.floor(state.hours)));
      document.getElementById('hoursCount').textContent = Math.floor(state.hours);
    }

    // ==================== PROGRESS ====================
    function updateProgress() {
      const progress = (audio.currentTime / audio.duration) * 100 || 0;
      progressBar.style.width = progress + '%';
      currentTimeSpan.textContent = formatTime(audio.currentTime);
    }

    function formatTime(seconds) {
      if (isNaN(seconds)) return '0:00';
      const mins = Math.floor(seconds / 60);
      const secs = Math.floor(seconds % 60);
      return `${mins}:${secs.toString().padStart(2, '0')}`;
    }

    function seek(e) {
      const rect = progressContainer.getBoundingClientRect();
      const percent = (e.clientX - rect.left) / rect.width;
      audio.currentTime = percent * audio.duration;
    }

    // ==================== RENDER SONGS ====================
    function renderSongs() {
      let filtered = songs;
      
      // Apply tab filter
      if (state.currentTab === 'favorites') {
        filtered = filtered.filter(s => state.favorites.includes(s.id));
      } else if (state.currentTab === 'aartis') {
        filtered = filtered.filter(s => s.genre === 'Aarti');
      } else if (state.currentTab === 'bhajans') {
        filtered = filtered.filter(s => s.genre === 'Bhajan');
      }
      
      // Apply search
      if (state.searchTerm) {
        filtered = filtered.filter(s => 
          s.title.toLowerCase().includes(state.searchTerm) ||
          s.artist.toLowerCase().includes(state.searchTerm)
        );
      }

      document.getElementById('songCount').textContent = filtered.length + ' songs';

      songList.innerHTML = filtered.map((song, idx) => {
        const originalIndex = songs.findIndex(s => s.id === song.id);
        const isPlaying = originalIndex === state.currentIndex;
        const isFav = state.favorites.includes(song.id);
        
        return `
          <li class="song-item ${isPlaying ? 'playing' : ''}" onclick="window.playSong(${originalIndex})">
            <span class="song-number">${idx + 1}</span>
            <div class="song-details">
              <div class="song-name">${song.title}</div>
              <div class="song-meta">
                <span>${song.artist}</span>
                <span>${formatTime(song.duration)}</span>
              </div>
            </div>
            <span class="song-fav ${isFav ? 'active' : ''}" onclick="event.stopPropagation(); toggleFavoriteById(${song.id})">
              <i class="fas fa-heart"></i>
            </span>
          </li>
        `;
      }).join('');
    }

    // ==================== FAVORITES ====================
    function toggleFavorite() {
      const song = songs[state.currentIndex];
      if (state.favorites.includes(song.id)) {
        state.favorites = state.favorites.filter(id => id !== song.id);
        showToast('Removed from favorites');
      } else {
        state.favorites.push(song.id);
        showToast('Added to favorites');
      }
      localStorage.setItem('fav', JSON.stringify(state.favorites));
      updateFavoriteButton();
      renderSongs();
    }

    function toggleFavoriteById(id) {
      if (state.favorites.includes(id)) {
        state.favorites = state.favorites.filter(fid => fid !== id);
        showToast('Removed from favorites');
      } else {
        state.favorites.push(id);
        showToast('Added to favorites');
      }
      localStorage.setItem('fav', JSON.stringify(state.favorites));
      if (id === songs[state.currentIndex]?.id) {
        updateFavoriteButton();
      }
      renderSongs();
    }

    function updateFavoriteButton() {
      const song = songs[state.currentIndex];
      const isFav = state.favorites.includes(song?.id);
      favoriteBtn.innerHTML = isFav ? 
        '<i class="fas fa-heart"></i>' : 
        '<i class="far fa-heart"></i>';
    }

    // ==================== SHUFFLE & REPEAT ====================
    function toggleShuffle() {
      state.isShuffle = !state.isShuffle;
      shuffleBtn.style.color = state.isShuffle ? '#FF69B4' : 'white';
      showToast(state.isShuffle ? 'Shuffle ON' : 'Shuffle OFF');
    }

    function toggleRepeat() {
      state.isRepeat = !state.isRepeat;
      repeatBtn.style.color = state.isRepeat ? '#FF69B4' : 'white';
      showToast(state.isRepeat ? 'Repeat ON' : 'Repeat OFF');
    }

    // ==================== TABS ====================
    function switchTab(tab) {
      state.currentTab = tab;
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      document.querySelector(`[data-tab="${tab}"]`).classList.add('active');
      renderSongs();
    }

    // ==================== SHARE ====================
    function shareSong() {
      const song = songs[state.currentIndex];
      const text = `🕉️ Radhaswami Divine\n\nListening to: ${song.title}\n${song.artist}\n\n"राधास्वामी दया की दया"`;
      
      if (navigator.share) {
        navigator.share({
          title: 'Radhaswami Bhajan',
          text: text,
          url: window.location.href
        });
      } else {
        window.open(`https://wa.me/?text=${encodeURIComponent(text)}`, '_blank');
      }
    }

    // ==================== INFO MODAL ====================
    function showInfo() {
      infoModal.classList.add('active');
    }

    function closeModal() {
      infoModal.classList.remove('active');
    }

    // ==================== UTILITIES ====================
    function updateStats() {
      document.getElementById('totalBhajans').textContent = songs.length;
      document.getElementById('favoritesCount').textContent = state.favorites.length;
      document.getElementById('playsCount').textContent = state.plays;
      document.getElementById('hoursCount').textContent = Math.floor(state.hours);
    }

    function showToast(message, type = 'success') {
      toast.textContent = message;
      toast.style.background = type === 'success' ? 'rgba(0,0,0,0.8)' : '#EF4444';
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 2000);
    }

    function scrollToTop() {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // ==================== PWA INSTALL ====================
    let deferredPrompt;
    window.addEventListener('beforeinstallprompt', (e) => {
      e.preventDefault();
      deferredPrompt = e;
      
      // Show install button in floating buttons
      const installBtn = document.createElement('button');
      installBtn.className = 'float-btn';
      installBtn.innerHTML = '<i class="fas fa-download"></i>';
      installBtn.style.bottom = '80px';
      installBtn.onclick = installPWA;
      document.body.appendChild(installBtn);
    });

    function installPWA() {
      if (!deferredPrompt) return;
      deferredPrompt.prompt();
      deferredPrompt.userChoice.then(() => {
        deferredPrompt = null;
      });
    }

    // ==================== EXPOSE GLOBALLY ====================
    window.playSong = playSong;
    window.toggleFavoriteById = toggleFavoriteById;
    window.closeModal = closeModal;

    // ==================== START ====================
    init();
  </script>
</body>
</html>
